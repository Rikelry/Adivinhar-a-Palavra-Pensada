class $7d24393e98b145d1$export$52311f1ae316d7fa {
    constructor(matrix, selection, matrixService){
        this.matrix = matrix;
        this.selection = selection;
        this.matrixService = matrixService;
    }
    getMatrix() {
        return this.matrix.value;
    }
    addSelection(col) {
        this.selection.add(col);
    }
    getSelections() {
        return this.selection.toArray();
    }
    getSelectionCount(col) {
        return this.selection.getCount(col);
    }
    confirmMove() {
        const picks = this.selection.toArray();
        if (picks.length === 0) return;
        const next = this.matrixService.generateNext(this.matrix, picks);
        this.matrix.update(next);
        this.selection.clear();
    }
}


class $27dd424bb661d826$export$373e09b633948dc {
    constructor(boardEl, buttonsEl, moveTextEl){
        this.boardEl = boardEl;
        this.buttonsEl = buttonsEl;
        this.moveTextEl = moveTextEl;
    }
    renderMatrix(matrix) {
        this.boardEl.innerHTML = "";
        matrix.forEach((row)=>{
            const rowDiv = document.createElement("div");
            rowDiv.className = "row";
            row.forEach((cell)=>{
                const cellDiv = document.createElement("div");
                cellDiv.className = "cell";
                cellDiv.innerHTML = `<div class="inner"><span>${cell}</span></div>`;
                rowDiv.appendChild(cellDiv);
            });
            this.boardEl.appendChild(rowDiv);
        });
    }
    renderButtons(cols, onClick) {
        this.buttonsEl.innerHTML = "";
        for(let i = 1; i <= cols; i++){
            const btn = document.createElement("button");
            btn.className = "col-btn";
            btn.textContent = i.toString();
            btn.addEventListener("click", ()=>onClick(i, btn));
            this.buttonsEl.appendChild(btn);
        }
    }
    updateBadge(btn, value) {
        let badge = btn.querySelector(".badge");
        if (!badge) {
            badge = document.createElement("div");
            badge.className = "badge";
            btn.appendChild(badge);
        }
        badge.textContent = value.toString();
    }
    updateMoveText(text) {
        this.moveTextEl.textContent = text;
    }
}


class $89443f7391fc8358$export$f3f3f6c0124f08de {
    constructor(useCase, view, confirmBtn){
        this.useCase = useCase;
        this.view = view;
        this.confirmBtn = confirmBtn;
    }
    init() {
        this.render();
        this.confirmBtn.addEventListener("click", ()=>{
            this.useCase.confirmMove();
            this.render();
        });
        document.addEventListener("keydown", (e)=>{
            const num = parseInt(e.key);
            if (!isNaN(num)) {
                this.useCase.addSelection(num);
                this.updateMoveText();
            }
            if (e.key === "Enter") {
                this.useCase.confirmMove();
                this.render();
            }
        });
    }
    render() {
        const matrix = this.useCase.getMatrix();
        this.view.renderMatrix(matrix);
        this.view.renderButtons(matrix[0].length, (col, btn)=>{
            this.useCase.addSelection(col);
            this.view.updateBadge(btn, this.useCase.getSelectionCount(col));
            this.updateMoveText();
        });
        this.updateMoveText();
    }
    updateMoveText() {
        const picks = this.useCase.getSelections();
        const text = picks.length > 0 ? `Jogada: ${picks.join(", ")}` : "Jogada: (vazia)";
        this.view.updateMoveText(text);
    }
}


